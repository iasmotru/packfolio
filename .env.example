# Окружение: dev | prod
ENV=prod

# JWT-секрет — сгенерируй случайную строку: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-random-secret

# Telegram Bot Token — получить у @BotFather
BOT_TOKEN=

# Пути (Railway подставит автоматически через volume)
DATABASE_URL=sqlite:////data/packfolio.db
UPLOAD_DIR=/data/uploads
