# ──────────────────────────────────────────────
# Packfolio — пример переменных окружения
# Скопируйте в .env и заполните своими значениями
# ──────────────────────────────────────────────

# Среда: dev | prod
ENV=dev

# Секрет для подписи JWT (обязательно сменить в проде!)
SECRET_KEY=super-secret-key-change-me

# Токен Telegram бота (получить у @BotFather)
# В dev-режиме без токена HMAC-проверка пропускается
BOT_TOKEN=

# Директория для загружаемых файлов
UPLOAD_DIR=./uploads

# Таймзона
TZ=Europe/Berlin

# ──────────────────────────────────────────────
# OCR (опционально)
# ──────────────────────────────────────────────
# Требует: pytesseract + Pillow + tesseract-ocr (системный пакет)
ENABLE_OCR=0

# ──────────────────────────────────────────────
# Apple Wallet (опционально)
# Без этих переменных — endpoint вернёт JSON с инструкцией
# ──────────────────────────────────────────────

# Pass Type Identifier из Apple Developer (напр. pass.com.yourcompany.packfolio)
PASS_TYPE_ID=

# Team ID из Apple Developer
TEAM_ID=

# Отображаемое имя организации в пассе
ORGANIZATION_NAME=Packfolio

# P12-сертификат Pass Type в Base64
# openssl base64 -in certificate.p12 | tr -d '\n'
CERT_P12_BASE64=

# Пароль от P12 (если есть)
CERT_P12_PASSWORD=

# WWDR-сертификат Apple в Base64
# Скачать: https://www.apple.com/certificateauthority/
# openssl base64 -in AppleWWDRCAG3.cer | tr -d '\n'
WWDR_CERT_BASE64=

# Базовый URL приложения (для QR-кода в пассе)
APP_BASE_URL=http://localhost:8000
